# ─────────────────────────────────────────────────────────────────
# SRV Detailing — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# Add these same keys in Vercel: Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────

# Google Service Account — used by /api/bookings to read/write Google Sheets
# Paste the full private key from your service account JSON, including -----BEGIN...-----
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Google Service Account email (found in your service account JSON as "client_email")
GOOGLE_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
